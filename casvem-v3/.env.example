# Copy this to .env and fill in your values

# ── LLM Backend ──────────────────────────────────────
LLM_BACKEND=gemini
LLM_MODEL=gemini-2.5-flash
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=1024

# Gemini (default)
GEMINI_API_KEY=your_gemini_api_key_here

# Ollama (uncomment to switch to open model)
# LLM_BACKEND=ollama
# LLM_MODEL=qwen3:4b
# OLLAMA_BASE_URL=http://localhost:11434

# ── Benchmark Judge ───────────────────────────────────
JUDGE_BACKEND=gemini
JUDGE_MODEL=gemini-2.5-flash

# ── Encoder + Reranker (always local, no API key) ─────
ENCODER_MODEL=all-MiniLM-L6-v2
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2

# ── HNSW ─────────────────────────────────────────────
HNSW_M=16
HNSW_EF_CONSTRUCTION=200
HNSW_EF_SEARCH=50
TOP_K=50
TOP_N=5

# ── Cache ─────────────────────────────────────────────
CACHE_L1_THRESHOLD=10
CACHE_L2_THRESHOLD=3
CACHE_L1_MAXSIZE=500
CACHE_L2_MAXSIZE=2000
CACHE_CONFIDENCE_DECAY=0.01
CACHE_HIT_SIMILARITY_THRESHOLD=0.92
MLP_RETRAIN_AFTER=1000
USE_MLP=false

# ── Context Builder ───────────────────────────────────
CONTEXT_TOKEN_BUDGET=2048
RERANKER_EARLY_EXIT_THRESHOLD=0.95

# ── Storage ───────────────────────────────────────────
SQLITE_PATH=data/casvem.db
HNSW_INDEX_PATH=data/hnsw_index.bin

# ── Dashboard ─────────────────────────────────────────
COST_DASHBOARD=true
MEM0_COST_PER_QUERY=0.02
GEMINI_COST_PER_1K_INPUT=0.0001
GEMINI_COST_PER_1K_OUTPUT=0.0004
